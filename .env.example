# ===========================================
# Typeset — Environment Variables
# Copy this to .env and fill in your values
# ===========================================

# Database password (used by both Postgres container and the API)
DB_PASSWORD=change-me-to-something-secure

# DigitalOcean Spaces (for storing rendered PDFs/DOCX)
# Create a Space at https://cloud.digitalocean.com/spaces
# Then create an API key at https://cloud.digitalocean.com/account/api/spaces
SPACES_KEY=
SPACES_SECRET=
SPACES_BUCKET=typeset-renders
SPACES_REGION=lon1
SPACES_ENDPOINT=https://lon1.digitaloceanspaces.com

# API key salt (any random string — used to hash API keys)
API_SECRET_SALT=change-me-to-a-random-string
