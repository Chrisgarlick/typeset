# ===========================================
# Typeset — Environment Variables
# Copy this to .env and fill in your values
# ===========================================

# Database password (used by both Postgres container and the API)
DB_PASSWORD=change-me-to-something-secure

# Shared API token. Any caller (frontend or API client) must send this as
# `Authorization: Bearer <token>`. Pick a long random string.
TYPESET_TOKEN=change-me-to-a-long-random-string

# Optional. Per-IP rate limit on /api/render and /api/preview (per 60s).
# Defaults to 10 if unset.
TYPESET_RATE_LIMIT_PER_MIN=10
